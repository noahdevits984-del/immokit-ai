# =============================================
# ImmoKit AI — Variables d'environnement
# Copiez en .env.local et remplissez les valeurs
# =============================================

# Supabase (supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY

# Anthropic Claude (console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-VOTRE_API_KEY

# URL publique de l'app
NEXT_PUBLIC_APP_URL=https://immokit.ai

# Stripe (dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE
STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET

# Stripe — IDs des prix (dashboard.stripe.com/products)
STRIPE_PRICE_STARTER=price_STARTER_ID
STRIPE_PRICE_PRO=price_PRO_ID
STRIPE_PRICE_AGENCY=price_AGENCY_ID

# Resend — Email (resend.com/api-keys)
RESEND_API_KEY=re_VOTRE_API_KEY
